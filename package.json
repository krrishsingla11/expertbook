{
  "name": "expertbook",
  "version": "1.0.0",
  "description": "Real-Time Expert Session Booking System",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "seed": "node seed.js",
    "start": "concurrently \"nodemon server.js\" \"cd client && npm start\"",
    "start:prod": "node server.js",
    "build": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "socket.io": "^4.6.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
